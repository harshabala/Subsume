    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
