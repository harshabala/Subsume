{
  "manifest_version": 3,
  "name": "Subsume",
  "version": "0.1.9",
  "key": "",
  "description": "Track movies & TV shows you discover while browsing. Get smart recommendations powered by AI.",
  "permissions": ["storage", "activeTab", "notifications", "alarms", "identity"],
  "host_permissions": [
    "https://api.themoviedb.org/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://www.omdbapi.com/*",
    "https://api.trakt.tv/*",
    "https://api.tvmaze.com/*",
    "https://query.wikidata.org/*",
    "https://en.wikipedia.org/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Subsume",
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "ui/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
